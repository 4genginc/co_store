generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String   @id @default(uuid())
  name        String
  company     String
  description String
  featured    Boolean  @default(false)
  image       String
  price       Int
  priceNote   String?
  clerkId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
