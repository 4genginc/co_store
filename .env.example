# .env.example — placeholder template
#
# Real values live in .env (gitignored). This file is committed and is the
# canonical list of every env var the project needs. Copy it to .env and
# fill in the placeholders before running `npm run dev`.
#
# Sections are grouped by the phase that introduces the var (see PLAN.md).

# ─────────────────────────────────────────────────────────────────────────────
# Phase 2 · Prisma + Supabase Postgres
# Get both URLs from the Supabase dashboard → Project Settings → "ORM" tab.
# DATABASE_URL is the pooled connection (port 6543) used by Prisma at runtime.
# DIRECT_URL is the direct connection (port 5432) used by the Prisma CLI for
# migrations / DDL. See docs/learning.md L-002.
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres.PROJECT_REF:DB_PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJECT_REF:DB_PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres"

# ─────────────────────────────────────────────────────────────────────────────
# Phase 4 · Clerk authentication
# Get both keys from the Clerk dashboard → API Keys.
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_CLERK_PUBLISHABLE_KEY
CLERK_SECRET_KEY=sk_test_REPLACE_WITH_CLERK_SECRET_KEY

# ─────────────────────────────────────────────────────────────────────────────
# Phase 5 · Admin allow-list (bootstrap)
# Comma-separated Clerk user IDs. Unset, empty, or whitespace-only means no
# admins (fail-closed). See docs/learning.md L-005 for design rationale and
# the future migration path to a database-backed role model.
# ─────────────────────────────────────────────────────────────────────────────
ADMIN_USER_IDS=user_REPLACE_WITH_CLERK_USER_ID_1,user_REPLACE_WITH_CLERK_USER_ID_2

# ─────────────────────────────────────────────────────────────────────────────
# Phase 6 · Supabase Storage + supabase-js (image upload)
# Get URL and publishable key from the Supabase dashboard → Project Settings →
# "Framework" tab (App Frameworks → Next.js). These are the keys consumed by
# `@supabase/supabase-js` for browser-side calls. See PLAN.md 6.3.
# SUPABASE_BUCKET is the name of the storage bucket created for product images.
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_WITH_SUPABASE_PUBLISHABLE_KEY
SUPABASE_BUCKET=REPLACE_WITH_BUCKET_NAME

# ─────────────────────────────────────────────────────────────────────────────
# Phase 10 · Stripe embedded checkout
# Get both keys from the Stripe dashboard → Developers → API keys (test mode).
# NEXT_PUBLIC_WEBSITE_URL is the absolute URL used for Stripe `return_url` and
# any other absolute links. Use http://localhost:3000 in local development.
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_STRIPE_PUBLISHABLE_KEY
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_STRIPE_SECRET_KEY
NEXT_PUBLIC_WEBSITE_URL=http://localhost:3000
